# ─── Application ─────────────────────────────────────────
APP_ENV=development
APP_DOMAIN=localhost

# ─── Keycloak ─────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=easy-immo
KEYCLOAK_CLIENT_ID_WEB=easy-immo-web
KEYCLOAK_CLIENT_ID_MOBILE=easy-immo-mobile
KEYCLOAK_CLIENT_ID_BACKEND=easy-immo-backend
KEYCLOAK_CLIENT_SECRET_BACKEND=change-me-in-production

# ─── PostgreSQL (commun) ───────────────────────────────────
POSTGRES_PASSWORD=pgpass123

# ─── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=redis123

# ─── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_USER=easy
RABBITMQ_PASS=easy123

# ─── MinIO ────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=easy-immo-bucket

# ─── Mobile Money ─────────────────────────────────────────
MTN_MOMO_SUBSCRIPTION_KEY=your-mtn-subscription-key
MTN_MOMO_API_USER=your-mtn-api-user
MTN_MOMO_API_KEY=your-mtn-api-key
