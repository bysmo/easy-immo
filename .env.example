ORANGE_MONEY_CLIENT_ID=your-orange-client-id
ORANGE_MONEY_CLIENT_SECRET=your-orange-client-secret
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay

# ─── Notifications ────────────────────────────────────────
FCM_SERVER_KEY=your-firebase-server-key
AFRICAS_TALKING_API_KEY=your-at-api-key
AFRICAS_TALKING_USERNAME=sandbox
MAILGUN_API_KEY=your-mailgun-key
MAILGUN_DOMAIN=mg.easy-immo.com

# ─── Grafana ──────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin123
